# .streamlit/secrets.toml
# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit it.
#
# Streamlit reads these automatically; they are accessible via st.secrets["KEY"]
# or os.environ["KEY"] when set here.

SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_KEY = "your-supabase-service-role-or-anon-key"
